{
    "openapi": "3.0.0",
    "info": {
        "title": "API Clientes",
        "description": "Documentación de la API para la gestión de clientes",
        "contact": {
            "email": "luis.espinoza@ldrsolutions.com.mx"
        },
        "version": "1.0.0"
    },
    "paths": {
        "/api/login/{numcolaborador}": {
            "post": {
                "tags": [
                    "Autenticación"
                ],
                "summary": "Autenticar empleado por número de colaborador",
                "description": "Busca un empleado por número de colaborador y genera un token de acceso.",
                "operationId": "cb7a54231880b631e8caab3597175f10",
                "parameters": [
                    {
                        "name": "numcolaborador",
                        "in": "path",
                        "description": "Número de colaborador",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "example": "12345"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Autenticación exitosa",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Autenticación exitosa"
                                        },
                                        "user": {
                                            "type": "object"
                                        },
                                        "token": {
                                            "type": "string",
                                            "example": "1|abc123token"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Empleado no encontrado",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "error": {
                                            "type": "string",
                                            "example": "Empleado no encontrado."
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "500": {
                        "description": "Error interno",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "error": {
                                            "type": "string",
                                            "example": "Error al autenticar empleado"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/GetClientes": {
            "get": {
                "tags": [
                    "Clientes"
                ],
                "summary": "Obtener listado de clientes",
                "description": "Retorna todos los clientes registrados en el sistema.",
                "operationId": "fdd0de377cd637880b7d865b3b698598",
                "responses": {
                    "200": {
                        "description": "Listado obtenido correctamente"
                    },
                    "401": {
                        "description": "No autenticado"
                    },
                    "500": {
                        "description": "Error interno"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        }
    },
    "components": {
        "securitySchemes": {
            "sanctum": {
                "type": "http",
                "description": "Ingresa el token con el formato: Bearer {token}",
                "bearerFormat": "JWT",
                "scheme": "bearer"
            }
        }
    },
    "tags": [
        {
            "name": "Autenticación",
            "description": "Autenticación"
        },
        {
            "name": "Clientes",
            "description": "Clientes"
        }
    ]
}